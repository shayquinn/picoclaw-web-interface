{
  "name": "picoclaw-web-interface",
  "version": "1.0.0",
  "description": "Web interface for PicoClaw AI agent",
  "main": "electron-main.js",
  "scripts": {
    "start": "node api-server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "picoclaw",
    "ai",
    "agent"
  ],
  "author": "PicoClaw contributors",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.picoclaw.app",
    "productName": "PicoClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!install_command_list",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "../build/picoclaw-windows-amd64.exe", "to": "bin/picoclaw.exe" }
      ],
      "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true
      }
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "extraResources": [
        { "from": "../build/picoclaw-darwin-arm64", "to": "bin/picoclaw" }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "extraResources": [
        { "from": "../build/picoclaw-linux-amd64", "to": "bin/picoclaw" }
      ]
    }
  }
}
